{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "api": {
        "ClusterId": "api",
        "Match": {
          "Path": "/api/{**catch-all}"
        }
      },
      "albumArt": {
        "ClusterId": "api",
        "Match": {
          "Path": "/getaa"
        }
      },
      "scalar": {
        "ClusterId": "api",
        "Match": {
          "Path": "/scalar"
        }
      },
      "frontend": {
        "ClusterId": "frontend",
        "Match": {
          "Path": "/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "api": {
        "Destinations": {
          "api1": {
            "Address": "http://localhost:5029/"
          }
        }
      },
      "frontend": {
        "Destinations": {
          "frontend1": {
            "Address": "https://localhost:7242/"
          }
        }
      }
    }
  }
}
